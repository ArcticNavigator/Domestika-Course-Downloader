# Normalize line endings so the repo is identical for every contributor,
# regardless of whether they're on Windows, macOS or Linux.
# Text is stored as LF in git and checked out as LF everywhere.
* text=auto eol=lf

# Explicit text types (kept LF on all platforms)
*.js    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.svg   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets — git must never touch these
*.png      binary
*.ico      binary
*.icns     binary
*.exe      binary
*.dmg      binary
*.AppImage binary
*.deb      binary
*.zip      binary
